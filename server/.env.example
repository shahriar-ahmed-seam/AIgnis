# ===========================================================================
# AInigma backend configuration. Copy to ".env" and fill in what you have.
# EVERYTHING IS OPTIONAL — with no keys set, the server runs fully in
# Simulated mode (no network) and every Live capability transparently falls
# back to the mock data layer.
# ===========================================================================

# --- Server ---
PORT=8787
HOST=0.0.0.0
# Comma-separated list of allowed CORS origins (the Vite frontend).
CORS_ORIGIN=http://localhost:5173

# ===========================================================================
# LIVE PASS — TEXT (LLM). Pick ONE provider. All options below are FREE tiers.
# Set LLM_PROVIDER to: "groq" | "openrouter" | "ollama" | "none"
# ===========================================================================
LLM_PROVIDER=none

# Option A — Groq (FREE, very fast). Runs Llama 3.x hosted.
#   Get a free key: https://console.groq.com/keys
#   Free model ids: llama-3.1-8b-instant | llama-3.3-70b-versatile
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# Option B — OpenRouter (FREE models available, OpenAI-compatible).
#   Get a free key: https://openrouter.ai/keys
#   Free model ids (suffix ":free"):
#     meta-llama/llama-3.1-8b-instruct:free
#     google/gemma-2-9b-it:free
#     mistralai/mistral-7b-instruct:free
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct:free

# Option C — Ollama (FREE, fully local, no key, no internet).
#   Install: https://ollama.com  then:  ollama pull llama3.1:8b
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# ===========================================================================
# LIVE PASS — IMAGE (Diffusion). Pick ONE. Both have FREE options.
# Set IMAGE_PROVIDER to: "pollinations" | "huggingface" | "none"
# ===========================================================================
IMAGE_PROVIDER=none

# Option A — Pollinations (FREE, NO KEY). Stable Diffusion / Flux hosted.
#   Just an image URL; nothing to configure. https://pollinations.ai
POLLINATIONS_MODEL=flux

# Option B — Hugging Face Inference API (FREE tier with a token).
#   Get a free token: https://huggingface.co/settings/tokens
#   Free model ids:
#     black-forest-labs/FLUX.1-schnell
#     stabilityai/stable-diffusion-xl-base-1.0
HF_API_TOKEN=
HF_MODEL=black-forest-labs/FLUX.1-schnell

# ===========================================================================
# MCP inventory server
# ===========================================================================
# Path to the local inventory file the MCP server reads (JSON).
MCP_INVENTORY_FILE=./data/inventory.json

# ===========================================================================
# Timeouts (ms) — guarded by the Fallback Controller (see design.md)
# ===========================================================================
LLM_TIMEOUT_MS=20000
IMAGE_TIMEOUT_MS=60000
MCP_TIMEOUT_MS=10000

# Frontend configuration. Copy to ".env.local" to override.

# Base URL of the AIgnis backend API. Defaults to http://localhost:8787.
# Leave unset for local development; set this when the backend is deployed.
VITE_API_URL=http://localhost:8787

# ---------------------------------------------------------------------------
# Serverless LLM copy (Vercel function at /api/generate)
# ---------------------------------------------------------------------------
# These are set in the VERCEL DASHBOARD (Project → Settings → Environment
# Variables), NOT committed. They let the deployed site generate real
# Groq/Llama copy for any typed or spoken idea, with no separate backend.
#
#   GROQ_API_KEY   your Groq key (required for live copy on the deployed site)
#   GROQ_MODEL     optional, defaults to llama-3.1-8b-instant
